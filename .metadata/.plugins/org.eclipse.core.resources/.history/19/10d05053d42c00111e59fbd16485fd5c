	public void clickAttachIcon() throws InterruptedException {
		
		// Verify dropdown
		List<WebElement> options = driver.findElements(
		    By.xpath("//*[contains(text(),'Attach files from record')]")
		);
		System.out.println("Dropdown appeared: " + options.size());
		if (options.size() > 0) {
			Actions actions = new Actions(driver);
		    actions.moveToElement(options.get(0)).pause(300).click().perform();
		    Thread.sleep(3000);
		    System.out.println("✅ Clicked: Attach files from record");
		}		
	}
	
	

	  	

