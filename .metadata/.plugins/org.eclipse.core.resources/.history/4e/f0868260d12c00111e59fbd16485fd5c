package attachFileFromRecord;

import java.time.Duration;
import java.util.List;

import org.openqa.selenium.By;
import org.openqa.selenium.JavascriptExecutor;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.interactions.Actions;
import org.openqa.selenium.support.ui.ExpectedConditions;
import org.openqa.selenium.support.ui.WebDriverWait;


import contact.contactlisting;

public class AttachFromRecordNavigation extends contactlisting {
	
	private final By Email =By.xpath("(//a[@title='Click to send email'])[1]");
	private final By Attachicon = By.xpath("//button[@id='attachFiles-1']");
	private final By Addfilefromrecord = By.xpath("//a[contains(text(),'Attach files from record')]");	
	
	
	//button[@id='attachFiles-1']
	//button[@data-cmd='attachFiles']
	//button[@data-title='Attach Files']
	
	protected WebDriverWait wait;
	public AttachFromRecordNavigation() {
        wait = new WebDriverWait(driver, Duration.ofSeconds(30));
    }

	
	public void hoverAndClickEmail() throws InterruptedException {

	    WebElement Emailadd = driver.findElement(Email);
	    Thread.sleep(500);
	    Emailadd.click();
	    System.out.println("Clicked on the email address");
	    Thread.sleep(2000);

	    // Step 1 — Find attach button
	    WebElement attachicon = wait.until(
	        ExpectedConditions.elementToBeClickable(Attachicon)
	    );
	    System.out.println("Found attach icon");

	    // Step 2 — Scroll it into view first
	    ((JavascriptExecutor) driver).executeScript(
	        "arguments[0].scrollIntoView({block: 'center', inline: 'center'});", 
	        attachicon
	    );
	    Thread.sleep(500);

	    // Step 3 — Highlight to visually confirm correct button
	    ((JavascriptExecutor) driver).executeScript(
	        "arguments[0].style.border='3px solid red'", attachicon
	    );
	    Thread.sleep(1000); // YOU WILL SEE RED BORDER ON CORRECT BUTTON IN BROWSER

	    // Step 4 — Move to element first, then click
	    Actions actions = new Actions(driver);
	    actions.moveToElement(attachicon)
	           .pause(1000)  // pause so hover effect registers
	           .click()
	           .perform();
	    
	    System.out.println("Clicked attach icon — checking if dropdown appeared...");
	    Thread.sleep(2000);

	    // Step 5 — Verify dropdown appeared
	    List<WebElement> options = driver.findElements(
	        By.xpath("//*[contains(text(),'Attach files from record')]")
	    );
	    System.out.println("Dropdown options visible: " + options.size());
	    
	    if (options.size() > 0) {
	        System.out.println("✅ Dropdown appeared! Clicking option...");
	        actions.moveToElement(options.get(0)).pause(300).click().perform();
	    } else {
	        System.out.println("❌ Dropdown did NOT appear — button click failed");
	        
	        // Print what is at button location in DOM
	        String tagBelow = (String) ((JavascriptExecutor) driver).executeScript(
	            "var el = document.elementFromPoint(" +
	            "arguments[0].getBoundingClientRect().left + arguments[0].offsetWidth/2," +
	            "arguments[0].getBoundingClientRect().top + arguments[0].offsetHeight/2);" +
	            "return el ? el.tagName + ' | id:' + el.id + ' | class:' + el.className : 'nothing';",
	            attachicon
	        );
	        System.out.println("Element actually at click point: " + tagBelow);
	    }
	}

	
	
	public void clickAttachIcon() {
//		waiting for attach icon visibility
		wait.until(ExpectedConditions.elementToBeClickable(Attachicon));
		System.out.println("found the attachicon");
		
		// JavaScript click for reliability
        WebElement attachBtn = driver.findElement(Attachicon);
        ((JavascriptExecutor) driver).executeScript("arguments[0].click();", attachBtn);
        System.out.println("Clicked the attach icon");
		
//		click the attach icon
		
//		driver.findElement(Attachicon).click();
//		System.out.println("clicked the attach icon");
		
//		wait till Addfilefromrecord option is visible
		
		wait.until(ExpectedConditions.visibilityOfElementLocated(Addfilefromrecord));
		System.out.println("found the element attachfilefrom record");
		
//		click the attachfile from record option
		
		driver.findElement(Addfilefromrecord).click();
		System.out.println("clicked Addfilefromrecord successfully");
		
	}
	
	

	  	

}
